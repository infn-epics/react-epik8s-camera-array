{
  "id": "example-injector",
  "name": "Injector Overview",
  "description": "Example dashboard showing injector beamline devices",
  "createdAt": "2025-01-01T00:00:00.000Z",
  "updatedAt": "2025-01-01T00:00:00.000Z",
  "widgets": [
    {
      "id": "w-cam1",
      "type": "camera",
      "config": {
        "title": "Target Camera",
        "pvPrefix": "EUAPS:TGT:CAM1",
        "streamUrl": "http://euaps-cam-tgt.local:8080/mjpeg"
      },
      "layout": { "x": 0, "y": 0, "w": 4, "h": 5 }
    },
    {
      "id": "w-mot1",
      "type": "motor",
      "config": {
        "title": "FP1 Horizontal",
        "pvPrefix": "EUAPS:FPRCK1:W:CTR:FP1-HMN-01",
        "min": 0,
        "max": 12,
        "precision": 4
      },
      "layout": { "x": 4, "y": 0, "w": 3, "h": 4 }
    },
    {
      "id": "w-bpm1",
      "type": "bpm",
      "config": {
        "title": "BPM Injector",
        "pvPrefix": "EUAPS:INJ:BPM1"
      },
      "layout": { "x": 7, "y": 0, "w": 3, "h": 3 }
    },
    {
      "id": "w-vac1",
      "type": "vacuum",
      "config": {
        "title": "Vacuum Gauge 1",
        "pvPrefix": "EUAPS:INJ:VAC1",
        "unit": "mbar",
        "alarmThreshold": 1e-5
      },
      "layout": { "x": 0, "y": 5, "w": 3, "h": 3 }
    },
    {
      "id": "w-ps1",
      "type": "power-supply",
      "config": {
        "title": "Dipole Magnet",
        "pvPrefix": "EUAPS:INJ:MAG-DIP1"
      },
      "layout": { "x": 3, "y": 5, "w": 3, "h": 4 }
    },
    {
      "id": "w-charge1",
      "type": "charge-monitor",
      "config": {
        "title": "Beam Charge",
        "pvPrefix": "EUAPS:INJ:ICT1",
        "unit": "pC",
        "historyLength": 100
      },
      "layout": { "x": 6, "y": 5, "w": 4, "h": 4 }
    },
    {
      "id": "w-pv1",
      "type": "pv-display",
      "config": {
        "title": "Beam Energy",
        "pvName": "EUAPS:ACC:ENERGY",
        "unit": "MeV",
        "fontSize": 32
      },
      "layout": { "x": 10, "y": 0, "w": 2, "h": 2 }
    },
    {
      "id": "w-plot1",
      "type": "plot",
      "config": {
        "title": "Beam Current (24h)",
        "pvName": "EUAPS:ACC:CURRENT",
        "timeRange": "24h",
        "color": "#4f8ff7"
      },
      "layout": { "x": 0, "y": 9, "w": 6, "h": 4 }
    }
  ]
}
